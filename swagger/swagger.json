{
  "openapi": "3.1.0",
  "info": {
    "title": "wormsec",
    "description": "",
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/api/ai/get_lua_context": {
      "get": {
        "tags": [
          "crate::api::ai"
        ],
        "operationId": "get_lua_context",
        "responses": {
          "200": {
            "description": "Successfully retreived the lua context",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LuaContext"
                }
              }
            }
          },
          "500": {
            "description": "Something went wrong retreiving the global lua context",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DefaultActionOutput"
                }
              }
            }
          }
        }
      }
    },
    "/api/ai/run_lua": {
      "post": {
        "tags": [
          "crate::api::ai"
        ],
        "operationId": "run_lua",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The given lua code ran successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DefaultActionOutput"
                }
              }
            }
          },
          "500": {
            "description": "Error executing lua code",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DefaultActionOutput"
                }
              }
            }
          }
        }
      }
    },
    "/api/front/machines": {
      "get": {
        "tags": [
          "crate::api::front::machines"
        ],
        "operationId": "get_machines",
        "responses": {
          "200": {
            "description": "List of all known machines with their connections",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Machine"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/front/warnings": {
      "get": {
        "tags": [
          "crate::api::front::warnings"
        ],
        "operationId": "get_warnings",
        "responses": {
          "200": {
            "description": "Per-machine warnings. Index matches machine ID from /machines. Pairing requests appear as 'warning'-level entries with pub_key and randomart fields.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WarningResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DefaultActionOutput": {
        "type": "object",
        "required": [
          "success",
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "success": {
            "type": "boolean"
          }
        }
      },
      "LuaContext": {
        "type": "object",
        "required": [
          "functions"
        ],
        "properties": {
          "functions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LuaFunctionInformation"
            }
          }
        }
      },
      "LuaFunctionInformation": {
        "type": "object",
        "required": [
          "name",
          "desc"
        ],
        "properties": {
          "desc": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "Machine": {
        "type": "object",
        "required": [
          "id",
          "label",
          "connections"
        ],
        "properties": {
          "connections": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 0
            },
            "description": "Indices of every other machine this one is connected to.\nCurrently: fully-connected (all others)."
          },
          "id": {
            "type": "integer",
            "description": "Sequential index used as a stable reference by the frontend",
            "minimum": 0
          },
          "label": {
            "type": "string",
            "description": "Human-readable label (our own hostname for self, the pairing label for peers)"
          }
        }
      },
      "Warning": {
        "type": "object",
        "required": [
          "log_level",
          "details"
        ],
        "properties": {
          "details": {
            "type": "string"
          },
          "log_level": {
            "type": "string"
          },
          "pub_key": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional: only present for pairing-request warnings"
          },
          "randomart": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional: randomart string for pairing confirmation"
          }
        }
      },
      "WarningResponse": {
        "type": "object",
        "required": [
          "warnings"
        ],
        "properties": {
          "warnings": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/Warning"
              }
            }
          }
        }
      }
    }
  },
  "tags": []
}
